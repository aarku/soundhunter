{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "C:\\**" },
        { "path": "D:\\**" },
        { "path": "E:\\**" },
        { "path": "F:\\**" }
      ]
    },
    {
      "identifier": "core:event:allow-emit-to",
      "allow": [{ "channel": "*" }]
    },
    {
      "identifier": "core:event:allow-listen",
      "allow": [{ "channel": "*" }]
    }
  ]
}
